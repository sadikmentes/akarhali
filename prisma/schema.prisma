generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTH
// ============================================================

enum Role {
  ADMIN
  EDITOR
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String
  role          Role      @default(ADMIN)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================
// CATALOG: SERVICES / CATEGORIES / PRICES
// ============================================================

model Service {
  id          String   @id @default(cuid())
  slug        String   @unique
  titleTr     String
  titleEn     String
  descriptionTr String?
  descriptionEn String?
  icon        String?
  image       String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  parentId    String?
  parent      Service?  @relation("ServiceTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    Service[] @relation("ServiceTree")
  prices      Price[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([parentId])
}

model Category {
  id        String   @id @default(cuid())
  slug      String   @unique
  nameTr    String
  nameEn    String
  order     Int      @default(0)
  prices    Price[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PriceUnit {
  M2
  PIECE
}

model Price {
  id                String    @id @default(cuid())
  serviceId         String
  service           Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  categoryId        String?
  category          Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  nameTr            String
  nameEn            String
  unit              PriceUnit @default(M2)
  basePrice         Float
  discountPrice     Float?
  isCampaignActive  Boolean   @default(false)
  isActive          Boolean   @default(true)
  order             Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([serviceId])
  @@index([categoryId])
}

// ============================================================
// CAMPAIGNS
// ============================================================

model Campaign {
  id               String   @id @default(cuid())
  titleTr          String
  titleEn          String
  descriptionTr    String?  
  descriptionEn    String?  
  image            String
  discountPercent  Int
  startDate        DateTime
  endDate          DateTime
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ============================================================
// GALLERY
// ============================================================

enum GalleryCategory {
  CARPET
  SOFA
  CURTAIN
  YATAK
  YORGAN
  BATTANIYE
  SANDALYE
  YASTIK
  BEFORE
  AFTER
}

model HeroSlide {
  id        String   @id @default(cuid())
  url       String
  publicId  String
  titleTr   String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GalleryImage {
  id            String          @id @default(cuid())
  url           String
  publicId      String
  category      GalleryCategory
  titleTr       String?
  titleEn       String?
  order         Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

// ============================================================
// SITE CONTENT / SETTINGS
// ============================================================

model SiteSettings {
  id                 String   @id @default("singleton")
  heroTitleTr        String?
  heroTitleEn        String?
  heroSubtitleTr     String?
  heroSubtitleEn     String?
  aboutTitleTr       String?
  aboutTitleEn       String?
  aboutContentTr     String?
  aboutContentEn     String?
  aboutImage         String?
  heroVideoUrl       String?
  featuresTitleTr    String?
  featuresSubtitleTr String?
  feature1TitleTr    String?
  feature1DescTr     String?
  feature2TitleTr    String?
  feature2DescTr     String?
  feature3TitleTr    String?
  feature3DescTr     String?
  feature4TitleTr    String?
  feature4DescTr     String?
  processTitleTr     String?
  processSubtitleTr  String?
  process1TitleTr    String?
  process1DescTr     String?
  process2TitleTr    String?
  process2DescTr     String?
  process3TitleTr    String?
  process3DescTr     String?
  process4TitleTr    String?
  process4DescTr     String?
  statsYearsExp      Int?     @default(10)
  statsHappyClients  Int?     @default(5000)
  statsProjectsDone  Int?     @default(12000)
  statsTeamMembers   Int?     @default(20)
  mapLatitude        Float?
  mapLongitude       Float?
  mapEmbedUrl        String?
  updatedAt          DateTime @updatedAt
}

model ContactInfo {
  id            String   @id @default("singleton")
  phone         String?
  phone2        String?
  whatsapp      String?
  email         String?
  addressTr     String?
  addressEn     String?
  workingHoursTr String?
  workingHoursEn String?
  updatedAt     DateTime @updatedAt
}

model SocialLinks {
  id         String   @id @default("singleton")
  instagram  String?
  facebook   String?
  whatsapp   String?
  youtube    String?
  tiktok     String?
  updatedAt  DateTime @updatedAt
}

model SeoSettings {
  id                String   @id @default("singleton")
  siteTitleTr       String?
  siteTitleEn       String?
  siteDescriptionTr String?  
  siteDescriptionEn String?  
  ogImage           String?
  twitterHandle     String?
  keywordsTr        String?
  keywordsEn        String?
  updatedAt         DateTime @updatedAt
}

// ============================================================
// CONTACT FORM SUBMISSIONS
// ============================================================

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  message   String   
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ============================================================
// FAQ
// ============================================================

model Faq {
  id          String   @id @default(cuid())
  questionTr  String
  questionEn  String
  answerTr    String
  answerEn    String
  order       Int      @default(0)
  isActive    Boolean  @default(true)
}
